rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email']) 
        && data.id is string 
        && data.id.size() <= 64
        && data.name is string 
        && data.name.size() <= 150
        && data.email is string 
        && data.email.size() <= 150
        && (!('password' in data) || (data.password is string && data.password.size() <= 128))
        && (!('role' in data) || (data.role is string && data.role.size() <= 100))
        && (!('department' in data) || (data.department is string && data.department.size() <= 100))
        && (!('lastActive' in data) || (data.lastActive is string && data.lastActive.size() <= 100))
        && (!('ipAddress' in data) || (data.ipAddress is string && data.ipAddress.size() <= 50))
        && (!('status' in data) || (data.status is string && data.status.size() <= 50));
    }

    // Official IAM user profiles collection
    match /users/{userId} {
      allow read, delete: if true;
      allow create, update: if isValidId(userId) && isValidUser(request.resource.data);
    }

    // System audit logs collection
    match /system_audit_logs/{logId} {
      allow read, create, update, delete: if true;
    }
  }
}
